<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portal: "My Home" entry -->
    <template id="portal_my_home_import"
              name="Show Import Projects"
              inherit_id="portal.portal_my_home"
              priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/pan_import_pro/static/description/icon.png'"/>
                <t t-set="title">Data Import</t>
                <t t-set="url" t-value="'/my/imports'"/>
                <t t-set="text">Bekijk je datamigratie-projecten</t>
                <t t-set="placeholder_count" t-value="'import_project_count'"/>
            </t>
        </xpath>
    </template>

    <!-- Portal: Project list -->
    <template id="portal_my_imports" name="My Import Projects">
        <t t-call="portal.portal_layout">
            <t t-set="title">Data Import</t>

            <div t-if="not projects" class="alert alert-info">
                Er zijn nog geen importprojecten.
            </div>
            <t t-else="">
                <div class="list-group">
                    <t t-foreach="projects" t-as="project">
                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                           t-attf-href="/my/import/#{project.id}">
                            <div>
                                <strong t-out="project.name"/>
                                <span t-if="project.open_question_count"
                                      class="badge text-bg-warning ms-2">
                                    <t t-out="project.open_question_count"/> open
                                </span>
                            </div>
                            <span t-attf-class="badge rounded-pill #{
                                'text-bg-success' if project.state == 'done'
                                else 'text-bg-info' if project.state == 'review'
                                else 'text-bg-secondary'
                            }" t-out="dict(project._fields['state'].selection).get(project.state)"/>
                        </a>
                    </t>
                </div>
            </t>
        </t>
    </template>

    <!-- Portal: Project detail -->
    <template id="portal_import_project" name="Import Project">
        <t t-call="portal.portal_layout">
            <t t-set="title" t-value="project.name"/>

            <t t-set="o_portal_fullwidth_alert" groups="base.group_user">
                <t t-call="portal.portal_back_in_edit_mode">
                    <t t-set="backend_url" t-value="'/odoo/import-pro/%s' % project.id"/>
                </t>
            </t>

            <!-- Project header -->
            <div class="row mb-4">
                <div class="col-12">
                    <h3 t-out="project.name"/>
                    <span t-attf-class="badge rounded-pill #{
                        'text-bg-success' if project.state == 'done'
                        else 'text-bg-info' if project.state == 'review'
                        else 'text-bg-secondary'
                    }" t-out="dict(project._fields['state'].selection).get(project.state)"/>
                </div>
            </div>

            <!-- Step indicator: what does the client need to do? -->
            <t t-if="project.open_question_count and project.state == 'in_progress'">
                <div class="alert alert-warning border-0 shadow-sm mb-4">
                    <h5 class="alert-heading mb-1">Jouw input is nodig</h5>
                    <p class="mb-0">
                        Er <t t-if="project.open_question_count == 1">is</t><t t-else="">zijn</t>
                        <strong><t t-out="project.open_question_count"/>
                        <t t-if="project.open_question_count == 1">vraag</t><t t-else="">vragen</t></strong>
                        die we nodig hebben om verder te gaan.
                        Beantwoord ze hieronder — je hoeft niet alles in één keer te doen.
                    </p>
                </div>
            </t>

            <t t-if="not project.open_question_count and project.state == 'in_progress' and project.question_ids">
                <div class="alert alert-success border-0 shadow-sm mb-4">
                    <h5 class="alert-heading mb-1">Alle vragen beantwoord</h5>
                    <p class="mb-0">
                        We gaan verder met de import. Je hoort van ons zodra er een plan klaarstaat om te reviewen.
                    </p>
                </div>
            </t>

            <t t-if="project.state == 'review'">
                <div class="alert alert-info border-0 shadow-sm mb-4">
                    <h5 class="alert-heading mb-1">Controleer het importplan</h5>
                    <p class="mb-0">
                        Hieronder staat wat we gaan importeren. Klopt het? Laat het ons weten.
                    </p>
                </div>
            </t>

            <t t-if="project.state == 'done'">
                <div class="alert alert-success border-0 shadow-sm mb-4">
                    <h5 class="alert-heading mb-1">Import afgerond</h5>
                    <p class="mb-0">
                        Alle data is geïmporteerd. Controleer de resultaten in Odoo.
                        Klopt er iets niet? Laat het ons weten — we kunnen altijd een nieuwe ronde draaien.
                    </p>
                </div>
            </t>

            <!-- Questions -->
            <div t-if="project.question_ids" class="mb-5">
                <h4 class="mb-3">Vragen</h4>

                <form method="POST" t-attf-action="/my/import/#{project.id}/answer">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <t t-foreach="project.question_ids" t-as="question">
                        <div t-attf-class="card mb-3 #{
                            'border-success' if question.state == 'answered' else ''
                        }">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="text-muted small">
                                        Vraag <t t-out="question_index + 1"/>
                                        <t t-if="question.source_document_id">
                                            ·
                                            <a t-attf-href="/web/content/#{question.source_document_id.attachment_id.id}?download=true"
                                               target="_blank"
                                               class="text-decoration-none">
                                                <i class="fa fa-file-o"/>
                                                <t t-out="question.source_document_id.name"/>
                                            </a>
                                            <t t-if="question.source">
                                                — <t t-out="question.source"/>
                                            </t>
                                        </t>
                                        <t t-elif="question.source">
                                            · <i class="fa fa-file-o"/> <t t-out="question.source"/>
                                        </t>
                                    </span>
                                    <span t-if="question.state == 'answered'"
                                          class="badge text-bg-success">Beantwoord</span>
                                    <span t-else=""
                                          class="badge text-bg-warning">Open</span>
                                </div>

                                <p class="mb-3" style="white-space: pre-line;"
                                   t-out="question.question"/>

                                <!-- Single choice: radio buttons -->
                                <t t-if="question.question_type == 'single'">
                                    <t t-foreach="question._get_options_list()" t-as="option">
                                        <div class="form-check mb-2">
                                            <input class="form-check-input"
                                                   type="radio"
                                                   t-attf-name="answer_#{question.id}"
                                                   t-att-value="option"
                                                   t-att-id="'opt_%s_%s' % (question.id, option_index)"
                                                   t-att-checked="'checked' if question.answer == option else None"/>
                                            <label class="form-check-label"
                                                   t-att-for="'opt_%s_%s' % (question.id, option_index)"
                                                   t-out="option"/>
                                        </div>
                                    </t>
                                </t>

                                <!-- Multiple choice: checkboxes -->
                                <t t-elif="question.question_type == 'multi'">
                                    <t t-set="selected_answers" t-value="(question.answer or '').split(' | ')"/>
                                    <t t-foreach="question._get_options_list()" t-as="option">
                                        <div class="form-check mb-2">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   t-attf-name="answer_#{question.id}_#{option_index}"
                                                   t-att-value="option"
                                                   t-att-id="'opt_%s_%s' % (question.id, option_index)"
                                                   t-att-checked="'checked' if option in selected_answers else None"/>
                                            <label class="form-check-label"
                                                   t-att-for="'opt_%s_%s' % (question.id, option_index)"
                                                   t-out="option"/>
                                        </div>
                                    </t>
                                </t>

                                <!-- Open: textarea -->
                                <t t-else="">
                                    <textarea class="form-control"
                                              t-attf-name="answer_#{question.id}"
                                              rows="2"
                                              placeholder="Typ je antwoord hier..."><t t-if="question.answer" t-out="question.answer"/></textarea>
                                </t>
                            </div>
                        </div>
                    </t>

                    <div class="text-end">
                        <button type="submit" class="btn btn-primary">
                            Antwoorden opslaan
                        </button>
                    </div>
                </form>
            </div>

            <!-- Import Plan -->
            <div t-if="project.plan_ids" class="mb-5">
                <h4 class="mb-3">Importplan</h4>
                <p class="text-muted mb-3">
                    Dit is wat we gaan importeren in Odoo.
                </p>

                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Wat</th>
                                <th>Omschrijving</th>
                                <th class="text-center">Aantal</th>
                                <th class="text-center">Actie</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="project.plan_ids" t-as="plan">
                                <tr>
                                    <td><code class="small" t-out="plan.model_name"/></td>
                                    <td t-out="plan.description"/>
                                    <td class="text-center" t-out="plan.record_count"/>
                                    <td class="text-center">
                                        <span t-attf-class="badge #{
                                            'text-bg-success' if plan.action == 'create'
                                            else 'text-bg-info' if plan.action == 'update'
                                            else 'text-bg-secondary'
                                        }" t-out="dict(plan._fields['action'].selection).get(plan.action)"/>
                                    </td>
                                    <td class="text-center">
                                        <span t-attf-class="badge #{
                                            'text-bg-success' if plan.state == 'done'
                                            else 'text-bg-danger' if plan.state == 'error'
                                            else 'text-bg-light text-dark'
                                        }" t-out="dict(plan._fields['state'].selection).get(plan.state)"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Import Log -->
            <div t-if="project.log_ids" class="mb-5">
                <h4 class="mb-3">Resultaten</h4>
                <p class="text-muted mb-3">
                    Wat er tot nu toe is geïmporteerd.
                </p>

                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Datum</th>
                                <th>Wat</th>
                                <th class="text-center">Aangemaakt</th>
                                <th class="text-center">Bijgewerkt</th>
                                <th class="text-center">Mislukt</th>
                                <th>Toelichting</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="project.log_ids" t-as="log">
                                <tr t-attf-class="#{'table-danger' if log.records_failed else ''}">
                                    <td><span t-field="log.create_date"
                                        t-options='{"widget": "date"}'/></td>
                                    <td><code class="small" t-out="log.model_name"/></td>
                                    <td class="text-center">
                                        <span t-if="log.records_created"
                                              class="text-success fw-bold"
                                              t-out="log.records_created"/>
                                        <span t-else="" class="text-muted">—</span>
                                    </td>
                                    <td class="text-center">
                                        <span t-if="log.records_updated"
                                              class="text-info fw-bold"
                                              t-out="log.records_updated"/>
                                        <span t-else="" class="text-muted">—</span>
                                    </td>
                                    <td class="text-center">
                                        <span t-if="log.records_failed"
                                              class="text-danger fw-bold"
                                              t-out="log.records_failed"/>
                                        <span t-else="" class="text-muted">—</span>
                                    </td>
                                    <td class="small" t-out="log.summary"/>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>

        </t>
    </template>

</odoo>
