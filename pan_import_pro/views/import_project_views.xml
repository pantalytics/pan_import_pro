<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="pan_import_project_view_form" model="ir.ui.view">
        <field name="name">pan.import.project.form</field>
        <field name="model">pan.import.project</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start"
                            string="Start"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,done"
                           options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title mb-3">
                        <h1>
                            <field name="name" placeholder="e.g. Emovr B.V. — Klanten &amp; Producten"/>
                        </h1>
                    </div>

                    <!-- Draft: explain what this is -->
                    <div class="alert alert-light border" invisible="state != 'draft'">
                        <p class="mb-0">
                            Click <strong>Start</strong> to create a Documents folder and questionnaire.
                        </p>
                    </div>

                    <!-- Main content -->
                    <div invisible="state == 'draft'">

                        <!-- Documents button -->
                        <field name="folder_id" invisible="1"/>
                        <div class="mb-4">
                            <button name="action_open_folder" string="Open Documents"
                                    type="object" class="btn btn-primary" icon="fa-folder-open"/>
                        </div>

                        <notebook>
                            <!-- Tab 1: Surveys -->
                            <page string="Surveys">
                                <field name="survey_ids">
                                    <list open_form_view="True">
                                        <field name="title"/>
                                        <field name="answer_done_count" string="Responses"/>
                                    </list>
                                </field>
                            </page>

                            <!-- Tab 2: Import Plan -->
                            <page string="Import Plan">
                                <field name="plan_ids">
                                    <list editable="bottom"
                                          decoration-success="state == 'done'"
                                          decoration-danger="state == 'error'"
                                          open_form_view="True">
                                        <field name="sequence" widget="handle"/>
                                        <field name="model_name"/>
                                        <field name="description"/>
                                        <field name="record_count"/>
                                        <field name="action" widget="badge"
                                               decoration-success="action == 'create'"
                                               decoration-info="action == 'update'"/>
                                        <field name="state" widget="badge"
                                               decoration-success="state == 'done'"
                                               decoration-danger="state == 'error'"
                                               invisible="state == 'planned'"/>
                                    </list>
                                </field>
                            </page>

                            <!-- Tab 2: Import Log -->
                            <page string="Log">
                                <field name="log_ids">
                                    <list decoration-danger="records_failed > 0"
                                          open_form_view="True">
                                        <field name="create_date" string="Date"/>
                                        <field name="model_name"/>
                                        <field name="records_created"/>
                                        <field name="records_updated"/>
                                        <field name="records_failed"/>
                                        <field name="name" string="Summary"/>
                                    </list>
                                </field>
                            </page>

                        </notebook>
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Import Log Form View -->
    <record id="pan_import_log_view_form" model="ir.ui.view">
        <field name="name">pan.import.log.form</field>
        <field name="model">pan.import.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title mb-3">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" readonly="1"/>
                            <field name="model_name"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="records_created"/>
                            <field name="records_updated"/>
                            <field name="records_failed"/>
                        </group>
                    </group>
                    <field name="notes"
                           placeholder="Details of what was imported, mapping decisions, issues..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Import Plan Form View -->
    <record id="pan_import_plan_view_form" model="ir.ui.view">
        <field name="name">pan.import.plan.form</field>
        <field name="model">pan.import.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="model_name"/>
                            <field name="description"/>
                            <field name="record_count"/>
                        </group>
                        <group>
                            <field name="action"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <field name="notes"
                           placeholder="Mapping details, field decisions, source references..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="pan_import_project_view_list" model="ir.ui.view">
        <field name="name">pan.import.project.list</field>
        <field name="model">pan.import.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'review'"
                       decoration-warning="state == 'approved'"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="pan_import_project_action" model="ir.actions.act_window">
        <field name="name">Import Projects</field>
        <field name="res_model">pan.import.project</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Start your first import
            </p>
            <p>
                Track your data migration into Odoo.
                Claude analyzes your files, you review and approve here.
            </p>
        </field>
    </record>

</odoo>
