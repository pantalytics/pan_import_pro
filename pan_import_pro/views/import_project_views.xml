<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="pan_import_project_view_form" model="ir.ui.view">
        <field name="name">pan.import.project.form</field>
        <field name="model">pan.import.project</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start"
                            string="Start"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_submit_for_review"
                            string="Submit for Review"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'in_progress'"/>
                    <button name="action_reopen"
                            string="Reopen"
                            type="object"
                            invisible="state not in ('review', 'done')"/>
                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'review'"
                            confirm="This marks the import as done. Continue?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,review,done"/>
                </header>
                <sheet>
                    <div class="oe_title mb-3">
                        <h1>
                            <field name="name" placeholder="e.g. Klanten &amp; Producten"/>
                        </h1>
                    </div>

                    <!-- Draft: explain what this is -->
                    <div class="alert alert-light border" invisible="state != 'draft'">
                        <p class="mb-0">
                            <strong>Import Pro</strong> tracks your data migration into Odoo.
                            Claude analyzes your files, asks questions here, and proposes an import plan for you to review.
                            Click <strong>Start</strong> to begin.
                        </p>
                    </div>

                    <notebook invisible="state == 'draft'">

                        <!-- Tab 1: Questions -->
                        <page string="Questions"
                              badge="open_question_count">
                            <div class="alert alert-warning" invisible="open_question_count == 0">
                                <strong><field name="open_question_count" class="fw-bold"/> open question(s)</strong>
                                — answer them so Claude can continue.
                            </div>
                            <field name="question_ids">
                                <list editable="bottom"
                                      decoration-muted="state == 'answered'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="question_type"/>
                                    <field name="question"/>
                                    <field name="options" optional="hide"/>
                                    <field name="answer"
                                           placeholder="Type your answer here..."/>
                                    <field name="source_document_id"/>
                                    <field name="source"/>
                                    <field name="state" widget="badge"
                                           decoration-warning="state == 'open'"
                                           decoration-success="state == 'answered'"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab 2: Import Plan -->
                        <page string="Import Plan">
                            <field name="plan_ids">
                                <list editable="bottom"
                                      decoration-success="state == 'done'"
                                      decoration-danger="state == 'error'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="model_name"/>
                                    <field name="description"/>
                                    <field name="record_count"/>
                                    <field name="action" widget="badge"
                                           decoration-success="action == 'create'"
                                           decoration-info="action == 'update'"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'done'"
                                           decoration-danger="state == 'error'"
                                           invisible="state == 'planned'"/>
                                    <field name="notes" optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab 3: Import Log -->
                        <page string="Log">
                            <field name="log_ids" readonly="1">
                                <list decoration-danger="records_failed > 0">
                                    <field name="create_date" string="Date"/>
                                    <field name="model_name"/>
                                    <field name="records_created"/>
                                    <field name="records_updated"/>
                                    <field name="records_failed"/>
                                    <field name="summary"/>
                                    <field name="error_details" optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab 4: Notes -->
                        <page string="Notes">
                            <field name="notes"
                                   placeholder="Free-form notes about this migration..."/>
                        </page>

                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="pan_import_project_view_list" model="ir.ui.view">
        <field name="name">pan.import.project.list</field>
        <field name="model">pan.import.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'review'"/>
                <field name="open_question_count" string="Open Questions"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="pan_import_project_action" model="ir.actions.act_window">
        <field name="name">Import Projects</field>
        <field name="res_model">pan.import.project</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Start your first import
            </p>
            <p>
                Track your data migration into Odoo.
                Claude analyzes your files, you review and approve here.
            </p>
        </field>
    </record>

</odoo>
