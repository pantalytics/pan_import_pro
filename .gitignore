# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Environment
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Client data — never commit original Excel files
migrations/*/input/*.xlsx
migrations/*/input/*.xls
migrations/*/input/*.csv
migrations/*/input/*.docx

# Cleaned and mapped data may contain sensitive client info
migrations/*/cleaned/
migrations/*/mapped/
migrations/*/logs/*.json
# But DO commit rapport markdown files
!migrations/*/logs/rapport_*.md

# Claude Code (keep skills, ignore the rest)
.claude/*
!.claude/skills/
